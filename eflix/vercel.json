{} 
{
    "name": "eflix",
    "version": 2,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.0",
            "maxDuration": 10
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/admin/(.*)",
            "dest": "/admin/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/js/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/images/$1"
        },
        {
            "src": "/(.*)\\.php",
            "dest": "/$1.php"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ],
    "env": {
        "SUPABASE_URL": "https://fzfrogtwasnljkywwmpg.supabase.co",
        "SUPABASE_ANON_KEY": "sb_publishable_yCZk0oiJUN_t9yiGd5RrOw_-am2tAQD"
    },
    "build": {
        "env": {
            "SUPABASE_URL": "https://fzfrogtwasnljkywwmpg.supabase.co",
            "SUPABASE_ANON_KEY": "sb_publishable_yCZk0oiJUN_t9yiGd5RrOw_-am2tAQD"
        }
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        },
        {
            "source": "/css/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/js/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/images/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "regions": ["sin1"],
    "crons": []
}